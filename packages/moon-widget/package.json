{
    "name": "moon-widget",
    "version": "0.1.0",
    "description": "React component for displaying moon phases",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./style.css": "./dist/index.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "*.css"
    ],
    "packageManager": "yarn@4.6.0",
    "keywords": [
        "react",
        "moon",
        "widget",
        "astronomy"
    ],
    "author": "Misha Topchilo <20854498+miksrv@users.noreply.github.com>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/miksrv/moon-widget.git",
        "directory": "packages/moon-widget"
    },
    "peerDependencies": {
        "react": ">=17.0.0",
        "react-dom": ">=17.0.0"
    },
    "dependencies": {
        "dayjs": "^1.11.13",
        "pixi.js": "^8.9.1",
        "suncalc": "^1.9.0"
    },
    "devDependencies": {
        "@testing-library/dom": "^10.4.0",
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "^16.3.0",
        "@types/jest": "^29.5.14",
        "@types/react": "^19.0.12",
        "@types/react-dom": "^19.0.4",
        "identity-obj-proxy": "^3.0.0",
        "jest": "^29.7.0",
        "jest-environment-jsdom": "^29.7.0",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "ts-jest": "^29.2.5",
        "tsup": "^8.4.0",
        "typescript": "^5.8.2"
    },
    "scripts": {
        "build": "tsup",
        "prepack": "yarn build",
        "test": "jest",
        "test:coverage": "jest --coverage",
        "test:watch": "jest --watch --testNamePattern"
    }
}
